APP_NAME="Creative Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://creative.localhost

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=creative
DB_USERNAME=creative
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=phpredis

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
